# Credentials pour `docker compose up`. Copier ce fichier en `.env` (gitignoré) et
# personnaliser si besoin — chaque variable a déjà une valeur de démonstration
# fonctionnelle dans docker-compose.yml (syntaxe ${VAR:-defaut}), donc `.env` est
# optionnel : `docker compose up --build` fonctionne même sans le créer.

# PostgreSQL (patient-service)
DB_USERNAME=medilabo
DB_PASSWORD=medilabo
DB_NAME=medilabo_patient

# MongoDB (notes-service) — pas d'authentification en local/démo
MONGO_DB=medilabo_notes

# Authentification HTTP Basic à la gateway (credentials à saisir sur la page de login du front)
SECURITY_USERNAME=admin
SECURITY_PASSWORD=medilabo